vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
f 49/49 50/50 51/51 52/52

# Back Face
v -0.71  0.00  -0.49
v -0.71  1.20  -0.49
v -0.14  1.20  -0.67
v -0.14  0.00  -0.67
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
f 53/53 54/54 55/55 56/56

# Right Face
v -0.14  0.00  -0.67
v -0.14  1.20  -0.67
v  0.04  1.20  -0.09
v  0.04  0.00  -0.09
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
f 57/57 58/58 59/59 60/60

# Front Face
v  0.04  0.00  -0.09
v  0.04  1.20  -0.09
v -0.53  1.20   0.09
v -0.53  0.00   0.09
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
f 61/61 62/62 63/63 64/64

# Bottom Face
v -0.53  0.00   0.09
v  0.04  0.00  -0.09
v -0.14  0.00  -0.67
v -0.71  0.00  -0.49
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
f 65/65 66/66 67/67 68/68

