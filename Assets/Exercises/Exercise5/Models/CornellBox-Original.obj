# The original Cornell Box in OBJ format (UV-fixed version for Unity)
# Added texture coordinates (vt) for tangent generation

mtllib CornellBox-Original.mtl

# ==========================
# Floor
# ==========================
g floor
usemtl floor
v -1.01  0.00   0.99
v  1.00  0.00   0.99
v  1.00  0.00  -1.04
v -0.99  0.00  -1.04
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
f 1/1 2/2 3/3 4/4

# ==========================
# Ceiling
# ==========================
g ceiling
usemtl ceiling
v -1.02  1.99   0.99  
v -1.02  1.99  -1.04
v  1.00  1.99  -1.04
v  1.00  1.99   0.99
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
f 5/5 6/6 7/7 8/8

# ==========================
# Back Wall
# ==========================
g backWall
usemtl backWall
v -0.99  0.00  -1.04 
v  1.00  0.00  -1.04
v  1.00  1.99  -1.04
v -1.02  1.99  -1.04
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
f 9/9 10/10 11/11 12/12

# ==========================
# Right Wall
# ==========================
g rightWall
usemtl rightWall
v  1.00  0.00  -1.04   
v  1.00  0.00   0.99
v  1.00  1.99   0.99
v  1.00  1.99  -1.04
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
f 13/13 14/14 15/15 16/16

# ==========================
# Left Wall
# ==========================
g leftWall
usemtl leftWall
v -1.01  0.00   0.99
v -0.99  0.00  -1.04
v -1.02  1.99  -1.04
v -1.02  1.99   0.99
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
f 17/17 18/18 19/19 20/20

# ==========================
# Short Box
# ==========================
g shortBox
usemtl shortBox

# Top Face
v  0.53  0.60   0.75 
v  0.70  0.60   0.17  
v  0.13  0.60   0.00
v -0.05  0.60   0.57
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
f 21/21 22/22 23/23 24/24

# Left Face
v -0.05  0.00   0.57
v -0.05  0.60   0.57
v  0.13  0.60   0.00 
v  0.13  0.00   0.00
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
f 25/25 26/26 27/27 28/28

# Front Face
v  0.53  0.00   0.75
v  0.53  0.60   0.75
v -0.05  0.60   0.57
v -0.05  0.00   0.57
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
f 29/29 30/30 31/31 32/32

# Right Face
v  0.70  0.00   0.17
v  0.70  0.60   0.17
v  0.53  0.60   0.75
v  0.53  0.00   0.75
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
f 33/33 34/34 35/35 36/36

# Back Face
v  0.13  0.00   0.00
v  0.13  0.60   0.00
v  0.70  0.60   0.17
v  0.70  0.00   0.17
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
f 37/37 38/38 39/39 40/40

# Bottom Face
v  0.53  0.00   0.75 
v  0.70  0.00   0.17  
v  0.13  0.00   0.00
v -0.05  0.00   0.57
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
f 41/41 42/42 43/43 44/44

# ==========================
# Tall Box
# ==========================
g tallBox
usemtl tallBox

# Top Face
v -0.53  1.20   0.09
v  0.04  1.20  -0.09
v -0.14  1.20  -0.67
v -0.71  1.20  -0.49
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
f 45/45 46/46 47/47 48/48

# Left Face
